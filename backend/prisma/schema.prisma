generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  passwordHash String
  albumPinHash String
  albumLayoutPreference String
  mediaLayoutPreference String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albums Album[]
  media Media[]
}

model Album {
  id Int @id @default(autoincrement())
  userId Int
  name String
  albumCoverMediaId Int?
  isLocked Boolean
  albumPosition Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  albumCoverMedia Media? @relation("AlbumCoverMedia", fields: [albumCoverMediaId], references: [id])
  media Media[] @relation("AlbumMedia")
}

model Media {
  id Int @id @default(autoincrement())
  userId Int
  albumId Int
  name String
  type String
  format String
  fileSize Int
  resolution String
  createdTime DateTime?
  importedTime DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean
  deletedTime DateTime?
  mediaPosition Int
  filePath String

  user User @relation(fields: [userId], references: [id])
  album Album @relation("AlbumMedia", fields: [albumId], references: [id])
  coverForAlbum Album[] @relation("AlbumCoverMedia")
}
